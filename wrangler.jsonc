{
  // Cloudflare Workers static-assets config: serves the built Astro site from dist/
  "name": "pst",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    // serve our custom /404.html for unknown URLs
    "not_found_handling": "404-page",
    // /apis/foo -> /apis/foo/ to match canonical trailing-slash URLs
    "html_handling": "auto-trailing-slash"
  }
}
