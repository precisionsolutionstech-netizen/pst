---
import Base from '../../layouts/Base.astro';
import workflows from '../../data/workflows.json';

export function getStaticPaths() {
  return workflows.map((w) => ({ params: { slug: w.slug }, props: { workflow: w } }));
}

const { workflow: w } = Astro.props;
const SITE = 'https://precisionsolutionstech.com';
const pagePath = `/workflows/${w.slug}/`;

const related = workflows.filter((r) => r.slug !== w.slug).slice(0, 4);

const title = `${w.name} | n8n Workflow Template`;
const description = w.shortDescription.length > 158
  ? w.shortDescription.slice(0, 155).replace(/\s+\S*$/, '') + '…'
  : w.shortDescription;

const priceNumber = w.price ? w.price.replace('$', '') : null;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
      { '@type': 'ListItem', position: 2, name: 'Workflows', item: `${SITE}/workflows/` },
      { '@type': 'ListItem', position: 3, name: w.name, item: `${SITE}${pagePath}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: w.name,
    description: w.shortDescription,
    url: `${SITE}${pagePath}`,
    category: 'n8n workflow template',
    brand: { '@type': 'Organization', name: 'Precision Solutions Tech' },
    ...(w.gumroadUrl && priceNumber
      ? {
          offers: {
            '@type': 'Offer',
            price: priceNumber,
            priceCurrency: 'USD',
            url: w.gumroadUrl,
            availability: 'https://schema.org/InStock',
          },
        }
      : {}),
  },
];
---

<Base
  title={title}
  description={description}
  path={pagePath}
  ogType="article"
  active="workflows"
  jsonLd={jsonLd}
>
  <div class="wrap">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/workflows/">Workflows</a></li>
        <li>{w.name}</li>
      </ol>
    </nav>

    <article>
      <header class="product-hero">
        <div class="hero-pills">
          <span class="pill pill-accent">n8n workflow template</span>
          {w.categories.map((c: string) => <span class="pill">{c}</span>)}
          {w.comingSoon && <span class="pill">Coming soon</span>}
        </div>
        <h1>{w.name}</h1>
        <p class="lead">{w.shortDescription}</p>

        <div class="cta-row">
          {w.gumroadUrl ? (
            <a class="btn btn-accent" href={w.gumroadUrl} rel="noopener">
              Buy on Gumroad — {w.price}
            </a>
          ) : w.n8nListed ? (
            <a class="btn btn-accent" href={w.n8nCreatorUrl} rel="noopener">
              Get it free on n8n
            </a>
          ) : (
            <a class="btn btn-secondary" href="https://solutionsprecision.gumroad.com/" rel="noopener">
              Coming soon — visit our Gumroad store
            </a>
          )}
          {w.gumroadUrl && w.n8nListed && (
            <a class="btn btn-secondary" href={w.n8nCreatorUrl} rel="noopener">
              Free version on n8n
            </a>
          )}
        </div>
        {w.n8nListed && w.n8nListingName && (
          <p class="cta-sub" style="margin-top: 6px;">
            Listed on the n8n marketplace as
            &ldquo;<a href={w.n8nCreatorUrl} rel="noopener">{w.n8nListingName}</a>&rdquo;.
          </p>
        )}
      </header>

      <div class="product-body workflow-body" set:html={w.contentHtml} />

      <section class="product-body" style="margin-top: 48px;">
        <div class="cta-row">
          {w.gumroadUrl ? (
            <a class="btn btn-accent" href={w.gumroadUrl} rel="noopener">
              Get {w.name} — {w.price} on Gumroad
            </a>
          ) : w.n8nListed ? (
            <a class="btn btn-accent" href={w.n8nCreatorUrl} rel="noopener">
              Get {w.name} free on n8n
            </a>
          ) : (
            <a class="btn btn-secondary" href="https://solutionsprecision.gumroad.com/" rel="noopener">
              Follow our Gumroad store for the release
            </a>
          )}
        </div>
        <p class="cta-sub">
          Stuck connecting credentials? Our
          <a href="/workflows/n8n-credential-setup-coach/">Credential Setup Coach</a>
          walks you through 60+ provider connections step by step.
        </p>
      </section>

      <section class="product-body related-apis" style="margin-top: 40px;">
        <h2>More n8n workflow templates</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={`/workflows/${r.slug}/`}>{r.name}</a> — {r.shortDescription.slice(0, 110)}{r.shortDescription.length > 110 ? '…' : ''}
            </li>
          ))}
        </ul>
        <p><a class="browse-all" href="/workflows/">Browse all workflow templates &rarr;</a></p>
      </section>
    </article>
  </div>
</Base>

<style>
  .workflow-body :global(h2) {
    font-size: 1.4rem;
    margin: 36px 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .workflow-body :global(blockquote) {
    margin: 1em 0;
    padding: 10px 18px;
    border-left: 3px solid var(--accent);
    background: var(--bg-soft);
    border-radius: 0 8px 8px 0;
  }
  .workflow-body :global(blockquote p) { margin: 0; }
</style>
