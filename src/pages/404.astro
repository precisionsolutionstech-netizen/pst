---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found | Precision Solutions Tech"
  description="The page you are looking for does not exist."
  path="/404/"
>
  <div class="wrap" style="padding: 96px 0; text-align: center;">
    <h1>Page not found</h1>
    <p style="color: var(--muted);">The page you are looking for does not exist or has moved.</p>
    <p style="margin-top: 24px;">
      <a class="btn btn-primary" href="/">Go home</a>
      <a class="btn btn-secondary" href="/apis/" style="margin-left: 8px;">Browse APIs</a>
      <a class="btn btn-secondary" href="/workflows/" style="margin-left: 8px;">Browse workflows</a>
    </p>
  </div>
</Base>
